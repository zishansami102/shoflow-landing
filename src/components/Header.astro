---
const DOWNLOAD_URL = "https://releases.shoflow.io/mac/ShoFlow-0.1.0-universal.dmg";
---

<header class="fixed inset-x-0 top-3 sm:top-5 z-50 px-4">
  <nav
    class="mx-auto flex h-14 max-w-[1080px] items-center justify-between gap-4 rounded-full border border-line bg-card/80 px-4 pl-5 shadow-soft backdrop-blur-md"
  >
    <a href="/" class="flex items-center gap-2.5" aria-label="ShoFlow home">
      <svg viewBox="0 0 40 40" fill="none" class="h-[26px] w-[26px] text-ink">
        <path d="M9.5 30.5 L16 24" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
        <path d="M24 16 L30.5 9.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
        <circle cx="7" cy="33" r="3.2" fill="currentColor"></circle>
        <circle cx="33" cy="7" r="3.2" fill="currentColor"></circle>
        <circle cx="20" cy="20" r="8.4" stroke="currentColor" stroke-width="2.4"></circle>
        <path d="M17.4 16.3 L24 20 L17.4 23.7 Z" fill="#E85D42"></path>
      </svg>
      <span class="text-[19px] font-bold tracking-tight text-ink">Sho<span class="text-accent">f</span>low</span>
    </a>

    <div class="flex items-center gap-2 sm:gap-5">
      <a href="#features" class="hidden text-[14px] font-medium text-muted transition-colors hover:text-ink sm:inline-block">Features</a>
      <a
        href={DOWNLOAD_URL}
        class="inline-flex items-center gap-2 rounded-full bg-ink px-4 py-2 text-[13.5px] font-semibold text-paper transition-transform duration-150 hover:-translate-y-px"
      >
        <svg viewBox="0 0 16 16" fill="currentColor" class="h-[15px] w-[15px]"><path d="M11.18 8.43c-.02-1.86 1.52-2.75 1.59-2.8-.87-1.27-2.22-1.44-2.7-1.46-1.15-.12-2.24.67-2.83.67-.58 0-1.48-.66-2.43-.64-1.25.02-2.4.73-3.05 1.85-1.3 2.25-.33 5.59.93 7.42.62.9 1.36 1.9 2.32 1.86.93-.04 1.28-.6 2.4-.6 1.12 0 1.43.6 2.41.58 1-.02 1.63-.91 2.24-1.81.71-1.04 1-2.05 1.01-2.1-.02-.01-1.94-.74-1.96-2.95l.03-.35zM9.42 3.01c.51-.62.86-1.49.76-2.35-.74.03-1.64.49-2.17 1.11-.47.55-.89 1.43-.78 2.27.83.07 1.67-.42 2.19-1.03z"></path></svg>
        Download for macOS
      </a>
    </div>
  </nav>
</header>
