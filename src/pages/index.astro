---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import MockGraph from "../components/MockGraph.tsx";

const DOWNLOAD_URL = "/mac/ShoFlow-0.1.0-universal.dmg";

const features = [
  {
    title: "Pick a starting point",
    body: "Choose any Claude scheduled task or agent instruction file you want to understand.",
  },
  {
    title: "ShoFlow maps it out",
    body: "It reads each starting point and traverses your setup — files, connected apps, and skills — rendering everything as one workflow graph.",
  },
  {
    title: "Explore, then edit",
    body: "Open the detailed flowchart for any task or file and edit it right in ShoFlow — the graph regenerates automatically.",
  },
];
---

<Layout>
  <Header />

  <main class="overflow-x-clip">
    <!-- Hero -->
    <section class="relative">
      <div class="hero-glow pointer-events-none absolute inset-x-0 top-0 h-[560px]"></div>

      <div class="relative mx-auto max-w-[1080px] px-5 pt-32 text-center sm:pt-32">
        <p data-animate class="mb-6 font-mono text-[12px] uppercase tracking-[0.18em] text-faint">
          Native Mac App · Free
        </p>

        <h1
          data-animate
          class="delay-100 mx-auto max-w-[20ch] font-serif text-[clamp(2.2rem,7vw,4.5rem)] font-medium leading-[1.04] tracking-[-0.01em] text-ink"
        >
          One <em class="italic text-accent">Visual Interface</em> for all your <em class="italic text-ink/90">Agentic Workflows</em>
        </h1>

        <p
          data-animate
          class="delay-200 mx-auto mt-7 max-w-[44ch] text-[17px] leading-relaxed text-muted sm:text-[17px]"
        >
        Shoflow reads your Scheduled Tasks,
        Files, Apps, and Skills, from your Claude App, and shows them beautifully in one place as connected workflow graphs.
        </p>

        <div data-animate class="delay-300 mt-9 flex flex-col items-center gap-3">
          <a
            href={DOWNLOAD_URL}
            class="inline-flex items-center gap-2.5 rounded-full bg-ink px-6 py-3.5 text-[15px] font-semibold text-paper shadow-lift transition-transform duration-150 hover:-translate-y-0.5"
          >
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-[17px] w-[17px]"><path d="M8 2.5V10.5M4.8 7l3.2 3.2L11.2 7M3 13.4h10"></path></svg>
            <span class="inline-flex items-center gap-1.5">Download for macOS<svg viewBox="0 0 16 16" fill="currentColor" class="h-[15px] w-[15px] translate-y-[-1px] translate-x-[-3px]"><path d="M11.18 8.43c-.02-1.86 1.52-2.75 1.59-2.8-.87-1.27-2.22-1.44-2.7-1.46-1.15-.12-2.24.67-2.83.67-.58 0-1.48-.66-2.43-.64-1.25.02-2.4.73-3.05 1.85-1.3 2.25-.33 5.59.93 7.42.62.9 1.36 1.9 2.32 1.86.93-.04 1.28-.6 2.4-.6 1.12 0 1.43.6 2.41.58 1-.02 1.63-.91 2.24-1.81.71-1.04 1-2.05 1.01-2.1-.02-.01-1.94-.74-1.96-2.95l.03-.35zM9.42 3.01c.51-.62.86-1.49.76-2.35-.74.03-1.64.49-2.17 1.11-.47.55-.89 1.43-.78 2.27.83.07 1.67-.42 2.19-1.03z"></path></svg></span>
          </a>
          <p class="font-mono text-[12px] tracking-[0.04em] text-faint">
            Apple Silicon &amp; Intel · macOS 11+
          </p>
        </div>

        <!-- Interactive app preview — the real React Flow engine, mocked data -->
        <div data-animate class="delay-400 mt-16 sm:mt-20">
          <div
            class="relative mx-auto w-full max-w-[1040px] overflow-hidden rounded-2xl border border-line shadow-lift"
            style="height: clamp(440px, 85vh, 600px); background: #15120F;"
          >
            <div class="absolute inset-0">
              <MockGraph client:visible />
            </div>
          </div>
          <p class="mt-3 font-mono text-[11px] tracking-[0.04em] text-faint">
            ↑ Live preview — drag, zoom, and click a node. One demo flow.
          </p>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section id="features" class="mx-auto max-w-[1080px] px-5 py-24 sm:py-32">
      <h2 data-animate class="font-serif text-[clamp(1.8rem,4vw,2.75rem)] font-medium leading-tight tracking-[-0.01em] text-ink">
        From <span class="italic">agent files</span> to a <span class="italic text-accent">living map</span>.
      </h2>
      <p data-animate class="delay-100 mt-3 max-w-[48ch] text-[16px] leading-relaxed text-muted">
        ShoFlow turns your scattered Claude workflows, built with scheduled tasks, markdown files, and connected apps into one
        clear, interactive graph.
      </p>

      <div class="mt-12 grid gap-5 sm:grid-cols-3">
        {features.map((f, i) => (
          <div
            data-animate
            class={`delay-${(i + 1) * 100} rounded-2xl border border-line bg-card p-6 shadow-soft`}
          >
            <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-lg bg-accent-soft text-accent">
              <span class="font-serif text-[18px] font-semibold">{i + 1}</span>
            </div>
            <h3 class="text-[17px] font-semibold tracking-tight text-ink">{f.title}</h3>
            <p class="mt-2 text-[14.5px] leading-relaxed text-muted">{f.body}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Closing CTA -->
    <section class="mx-auto max-w-[1080px] px-5 pb-28">
      <div data-animate class="rounded-3xl border border-line bg-surface px-8 py-16 text-center shadow-soft">
        <h2 class="mx-auto max-w-[18ch] font-serif text-[clamp(1.9rem,4.5vw,3rem)] font-medium leading-[1.08] tracking-[-0.01em] text-ink">
          See what your agents are up to.
        </h2>
        <a
          href={DOWNLOAD_URL}
          class="mt-8 inline-flex items-center gap-2.5 rounded-full bg-ink px-6 py-3.5 text-[15px] font-semibold text-paper shadow-lift transition-transform duration-150 hover:-translate-y-0.5"
        >
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-[17px] w-[17px]"><path d="M8 2.5V10.5M4.8 7l3.2 3.2L11.2 7M3 13.4h10"></path></svg>
          <span class="inline-flex items-center gap-1.5">Download for macOS<svg viewBox="0 0 16 16" fill="currentColor" class="h-[15px] w-[15px] translate-y-[-1px] translate-x-[-3px]"><path d="M11.18 8.43c-.02-1.86 1.52-2.75 1.59-2.8-.87-1.27-2.22-1.44-2.7-1.46-1.15-.12-2.24.67-2.83.67-.58 0-1.48-.66-2.43-.64-1.25.02-2.4.73-3.05 1.85-1.3 2.25-.33 5.59.93 7.42.62.9 1.36 1.9 2.32 1.86.93-.04 1.28-.6 2.4-.6 1.12 0 1.43.6 2.41.58 1-.02 1.63-.91 2.24-1.81.71-1.04 1-2.05 1.01-2.1-.02-.01-1.94-.74-1.96-2.95l.03-.35zM9.42 3.01c.51-.62.86-1.49.76-2.35-.74.03-1.64.49-2.17 1.11-.47.55-.89 1.43-.78 2.27.83.07 1.67-.42 2.19-1.03z"></path></svg></span>
        </a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-line">
      <div class="mx-auto flex max-w-[1080px] flex-col items-center justify-between gap-4 px-5 py-8 sm:flex-row">
        <div class="flex items-center gap-2.5">
          <svg viewBox="0 0 40 40" fill="none" class="h-5 w-5 text-ink">
            <path d="M9.5 30.5 L16 24" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
            <path d="M24 16 L30.5 9.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
            <circle cx="7" cy="33" r="3.2" fill="currentColor"></circle>
            <circle cx="33" cy="7" r="3.2" fill="currentColor"></circle>
            <circle cx="20" cy="20" r="8.4" stroke="currentColor" stroke-width="2.4"></circle>
            <path d="M17.4 16.3 L24 20 L17.4 23.7 Z" fill="#E85D42"></path>
          </svg>
          <span class="text-[14px] font-semibold text-ink">Sho<span class="text-accent">f</span>low</span>
        </div>
        <p class="font-mono text-[12px] text-faint">Local-only · no telemetry · © 2026 ShoFlow</p>
      </div>
    </footer>
  </main>
</Layout>
